
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  user
  admin
}

model User {
  id String @id @default(uuid()) 
  name String
  email String @unique
  password String
  role Roles
}

model Book{
  id Int @id @default(autoincrement())
  name String
  author String
  pageCount Int
}